{
  "name": "rcs-workspace",
  "version": "1.0.0",
  "description": "全栈工作区",
  "scripts": {
    "check-commit": "dotnet build $(find . -name '*.slnx' | head -n 1) --no-restore --nologo",
    "check-push": "dotnet build $(find . -name '*.slnx' | head -n 1) --configuration Release --no-restore --nologo"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.3",
    "autoprefixer": "^10.5.0",
    "husky": "^9.0.11",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "i18next": "^26.3.0",
    "react-i18next": "^17.0.8"
  }
}
